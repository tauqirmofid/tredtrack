generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  avatar    String?
  city      String?
  country   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runs      Run[]
}

model Run {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  duration  Int
  distance  Float
  avgSpeed  Float
  maxSpeed  Float?
  calories  Float?
  imageUrl  String?
  source    String   @default("manual")
  notes     String?
  createdAt DateTime @default(now())
}
