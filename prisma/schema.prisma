generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  avatar    String?
  heightCm  Float?
  weightKg  Float?
  dumbbellWeightKg Float?
  barbellWeightKg  Float?
  city      String?
  country   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runs      Run[]
  strengthLogs StrengthLog[]
  weightLogs WeightLog[]
}

model Run {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  duration  Int
  distance  Float
  avgSpeed  Float
  maxSpeed  Float?
  calories  Float?
  imageUrl  String?
  source    String   @default("manual")
  notes     String?
  createdAt DateTime @default(now())
}

model StrengthLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  equipment       String
  exercise        String
  weightKg        Float
  sets            Int
  reps            Int
  durationMinutes Int?
  volumeKg        Float
  calories        Float?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([userId, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  weightKg  Float
  source    String   @default("manual")
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}
